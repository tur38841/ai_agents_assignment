:root {
  --bg-dark: #052914;
  --bg-mid: #0d4825;
  --panel: rgba(10, 46, 24, 0.92);
  --line: #9ceb7d;
  --water-deep: #0c6b63;
  --water-shallow: #29a78b;
  --pad-stable: #84d46b;
  --pad-unstable: #d8f070;
  --pad-cracking: #f9d56e;
  --pad-broken: #355e52;
  --frog: #9bff7d;
  --text: #ecffd8;
  --shadow: rgba(0, 0, 0, 0.35);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  overflow: hidden;
  font-family: "Courier New", "Lucida Console", monospace;
  color: var(--text);
  background:
    radial-gradient(circle at top, rgba(82, 167, 81, 0.18), transparent 34%),
    linear-gradient(180deg, #123b1f 0%, #071b0f 100%);
}

.page-shell {
  width: min(1200px, calc(100% - 32px));
  margin: 0 auto;
  padding: 24px 0 32px;
  min-height: 100vh;
  display: grid;
  grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
  gap: 20px;
  align-items: start;
}

.game-panel,
.info-card {
  background: var(--panel);
  border: 3px solid rgba(156, 235, 125, 0.42);
  box-shadow: 0 18px 40px var(--shadow);
}

.game-panel {
  padding: 18px;
}

.panel-header,
.hud {
  display: flex;
  gap: 12px;
}

.panel-header {
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18px;
}

.eyebrow,
.hud-label {
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #b5f6a2;
}

.eyebrow {
  margin: 0 0 10px;
  font-size: 0.95rem;
}

h1,
h2,
button {
  font-family: "Courier New", "Lucida Console", monospace;
  font-weight: 700;
}

h1 {
  margin: 0;
  font-size: clamp(1.1rem, 2vw, 1.7rem);
  line-height: 1.4;
}

h2 {
  margin: 0 0 12px;
  font-size: 1rem;
  line-height: 1.5;
}

button {
  border: 0;
  padding: 14px 16px;
  background: #d6ff73;
